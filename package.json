{
  "name": "specmatter",
  "version": "0.1.0",
  "description": "Index and browse SPEC.md files from the terminal",
  "type": "module",
  "bin": {
    "specmatter": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.tsx",
    "postbuild": "chmod +x dist/cli.js",
    "test": "vitest"
  },
  "keywords": [
    "spec",
    "markdown",
    "cli",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
